# =========================================
# JOGOBICHO Backend - Variáveis de Ambiente
# Exemplo para uso local e deploy no Railway
# =========================================

# Ambiente da aplicação
NODE_ENV=development

# Porta usada pelo servidor
# No Railway, essa variável geralmente é injetada automaticamente.
PORT=3000

# Host de bind do servidor
HOST=0.0.0.0

# URL de conexão com PostgreSQL (Railway / local)
# Formato:
# postgresql://USUARIO:SENHA@HOST:PORT/BANCO?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jogobicho?schema=public

# Opcional: URL direta para operações administrativas/migrations
# DIRECT_URL=postgresql://postgres:postgres@localhost:5432/jogobicho?schema=public

# =========================================
# Segurança e CORS (opcional para próximas fases)
# =========================================

# Chave de assinatura para JWT (quando autenticação for habilitada)
# JWT_SECRET=troque-por-uma-chave-segura

# Origem permitida para frontend (exemplo local)
# CORS_ORIGIN=http://localhost:5173

# =========================================
# Observações Railway
# =========================================
# - Crie um serviço PostgreSQL no Railway.
# - Copie a connection string para DATABASE_URL.
# - Garanta que NODE_ENV=production em produção.
# - Não commitar arquivo .env real com segredos.
